# skillos_x_robot — environment configuration

# --- Backend Selection ---
# gemma4 (default, via OpenRouter) or gemini (Gemini AI API direct)
# AGENT_BACKEND=gemma4

# --- OpenRouter API ---
# Cloud inference via OpenRouter. Supports function calling.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model for the agent brain (default: Gemma 4 26B-A4B MoE)
# AGENT_MODEL=google/gemma-4-26b-a4b-it

# --- Gemini AI API ---
# Direct access to Google's Gemini models.
# Get your key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# Model for dream consolidation (default: same as agent model)
# DREAM_MODEL=google/gemma-4-26b-a4b-it

# --- Memory ---
# MEMORY_DIR=./memory

# --- Session Traces ---
# TRACES_DIR=./traces

# --- Simulation ---
# WebSocket port for 2D viewer state broadcast (default: 9091)
# SIM_WS_PORT=9091
# HTTP port for 2D viewer (default: 9092)
# SIM_HTTP_PORT=9092
